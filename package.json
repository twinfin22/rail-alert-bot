{
  "name": "rail-alert-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check:forbidden": "! grep -RInE '(reserve|cancel|payment|purchase)' --include='*.py' ktx src scripts",
    "poll": "bun src/poll.ts",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy": "wrangler deploy"
  },
  "dependencies": { "cheerio": "1.2.0" },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260713.1",
    "@types/bun": "1.3.14",
    "typescript": "7.0.2",
    "wrangler": "4.110.0"
  }
}
